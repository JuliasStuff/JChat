rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Chat messages: anyone with the invite code can read; anyone can create
    // small text messages. No edits or deletes.
    match /messages/{msgId} {
      allow read: if true;
      allow create: if request.resource.data.text is string
                 && request.resource.data.text.size() > 0
                 && request.resource.data.text.size() < 2000
                 && request.resource.data.author is string
                 && request.resource.data.author.size() < 80
                 && request.resource.data.authorId is string
                 && request.resource.data.authorId.size() < 200;
      allow update, delete: if false;
    }

    // FCM device tokens: clients write their own token. No client reads —
    // only the Cloud Function (admin SDK) needs them. Anyone can delete
    // (used by the in-app notifications toggle to opt out).
    match /tokens/{deviceId} {
      allow read: if false;
      allow delete: if true;
      allow create, update: if request.resource.data.token is string
                         && request.resource.data.token.size() < 500
                         && request.resource.data.deviceId is string
                         && request.resource.data.deviceId.size() < 200;
    }

    // Presence/profile: clients write their own profile.
    match /users/{deviceId} {
      allow read: if true;
      allow write: if request.resource.data.name is string
                && request.resource.data.name.size() < 80
                && request.resource.data.deviceId is string
                && request.resource.data.deviceId.size() < 200;
    }
  }
}
